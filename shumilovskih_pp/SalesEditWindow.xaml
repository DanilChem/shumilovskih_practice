<Window x:Class="shumilovskih_pp.SaleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление продажи" Height="500" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Новая продажа" FontSize="20" FontWeight="Bold" 
                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock x:Name="PartnerNameTextBlock" Text="Партнер: " FontWeight="Bold" 
                       FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,15"/>

            <TextBlock Text="Продукция *" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox x:Name="ProductComboBox" Height="30" Margin="0,0,0,15"
                      DisplayMemberPath="ProductName" SelectedValuePath="ProductId"/>

            <TextBlock Text="Количество *" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="QuantityTextBox" Height="30" Margin="0,0,0,15" Padding="5"
                     PreviewTextInput="NumberValidationTextBox"/>

            <TextBlock Text="Сумма *" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="TotalAmountTextBox" Height="30" Margin="0,0,0,15" Padding="5"
                     PreviewTextInput="NumberValidationTextBox"/>

            <TextBlock Text="Дата продажи *" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <DatePicker x:Name="SaleDatePicker" Height="30" Margin="0,0,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="120" Click="Save_Click" 
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="Отмена" Width="120" Click="Cancel_Click" 
                    Style="{StaticResource DangerButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>