<Window x:Class="shumilovskih_pp.PartnersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление партнерами - shumilovskih_pp" 
        Height="700" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добавление/Редактирование партнера" 
                   FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" 
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Наименование компании *" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="CompanyNameTextBox" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Тип партнера *" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <ComboBox x:Name="PartnerTypeComboBox" Height="30" Margin="0,0,0,15" 
                          IsEditable="True" TextSearch.TextPath="TypeName"/>

                <TextBlock Text="Рейтинг *" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="RatingTextBox" Height="30" Margin="0,0,0,15" Padding="5"
                         PreviewTextInput="NumberValidationTextBox"/>

                <TextBlock Text="ИНН" Margin="0,0,0,5"/>
                <TextBox x:Name="InnTextBox" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Юридический адрес" Margin="0,0,0,5"/>
                <TextBox x:Name="AddressTextBox" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="ФИО директора" Margin="0,0,0,5"/>
                <TextBox x:Name="DirectorNameTextBox" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Телефон" Margin="0,0,0,5"/>
                <TextBox x:Name="PhoneTextBox" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Email" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTextBox" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Логотип (путь к файлу)" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="LogoTextBox" Height="30" Grid.Column="0" Margin="0,0,5,0" Padding="5"/>
                    <Button Grid.Column="1" Content="Обзор..." Width="80" Height="30"
                            Click="BrowseLogo_Click" Style="{StaticResource NeutralButtonStyle}"/>
                </Grid>

                <TextBlock Text="Места продаж" Margin="0,0,0,5"/>
                <TextBox x:Name="SalesLocationsTextBox" Height="80" Margin="0,0,0,15" 
                         TextWrapping="Wrap" AcceptsReturn="True" Padding="5"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="Сохранить" Width="120" 
                    Click="Save_Click" Style="{StaticResource NeutralButtonStyle}"/>
            <Button Content="Отмена" Width="120" 
                    Click="Cancel_Click" Style="{StaticResource NeutralButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>