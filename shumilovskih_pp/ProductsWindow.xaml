<Window x:Class="shumilovskih_pp.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление продукцией - shumilovskih_pp" 
        Height="650" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Список продукции" FontSize="20" FontWeight="Bold" 
                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" x:Name="ProductsDataGrid" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionChanged="ProductsDataGrid_SelectionChanged"
                  Margin="0,0,0,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="50"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="150"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="100"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="100"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding MinPrice, StringFormat={}{0:N2} ₽}" Width="80"/>
                <DataGridTextColumn Header="Размер упаковки" Binding="{Binding PackageSize}" Width="120"/>
                <DataGridTextColumn Header="Вес" Binding="{Binding Weight}" Width="60"/>
                <DataGridTextColumn Header="Стандарт" Binding="{Binding StandardNumber}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Добавить" Width="100" Click="AddProduct_Click" 
                        Style="{StaticResource NeutralButtonStyle}"/>
                <Button Content="Изменить" Width="100" Click="EditProduct_Click" 
                       Style="{StaticResource NeutralButtonStyle}"/>
                <Button Content="Удалить" Width="100" Click="DeleteProduct_Click" 
                        Style="{StaticResource NeutralButtonStyle}"/>
            </StackPanel>

            <Button Grid.Column="1" Content="Закрыть" Width="100" Click="Close_Click" 
                    Style="{StaticResource NeutralButtonStyle}"/>
        </Grid>
    </Grid>
</Window>