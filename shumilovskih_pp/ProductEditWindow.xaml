<Window x:Class="shumilovskih_pp.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление продукцией" Height="600" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleTextBlock" 
                   Text="Добавление продукции" FontSize="20" FontWeight="Bold" 
                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Наименование *" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="ProductNameTextBox" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Артикул *" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="ArticleTextBox" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Тип" Margin="0,0,0,5"/>
                <TextBox x:Name="TypeTextBox" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Описание" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionTextBox" Height="60" Margin="0,0,0,15" 
                         TextWrapping="Wrap" AcceptsReturn="True" Padding="5"/>

                <TextBlock Text="Мин. цена *" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="MinPriceTextBox" Height="30" Margin="0,0,0,15" Padding="5"
                         PreviewTextInput="NumberValidationTextBox"/>

                <TextBlock Text="Размер упаковки" Margin="0,0,0,5"/>
                <TextBox x:Name="PackageSizeTextBox" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Вес" Margin="0,0,0,5"/>
                <TextBox x:Name="WeightTextBox" Height="30" Margin="0,0,0,15" Padding="5"
                         PreviewTextInput="NumberValidationTextBox"/>

                <TextBlock Text="Номер стандарта" Margin="0,0,0,5"/>
                <TextBox x:Name="StandardNumberTextBox" Height="30" Margin="0,0,0,15" Padding="5"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="ОК" Width="120" Click="Save_Click" 
                    Style="{StaticResource NeutralButtonStyle}"/>
            <Button Content="Закрыть" Width="120" Click="Cancel_Click" 
                    Style="{StaticResource NeutralButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>